============- 1) Create nutrition_templates  -============


CREATE TABLE nutrition_templates (
  id BIGINT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
  name VARCHAR(100) NOT NULL,
  description TEXT,
  goal ENUM('bulk','gain','fat_loss') NOT NULL,
  created_at DATETIME DEFAULT CURRENT_TIMESTAMP
); 


============- 2) Create nutrition_meals  -============


CREATE TABLE nutrition_meals (
  id BIGINT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
  template_id BIGINT UNSIGNED NOT NULL,
  name VARCHAR(100) NOT NULL,
  time VARCHAR(50),
  calories INT,
  protein INT,
  carbs INT,
  fats INT,
  FOREIGN KEY (template_id)
    REFERENCES nutrition_templates(id)
    ON DELETE CASCADE
);

============- 3) Create nutrition_ingredients  -============


CREATE TABLE nutrition_ingredients (
  id BIGINT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
  meal_id BIGINT UNSIGNED NOT NULL,
  name VARCHAR(100),
  amount VARCHAR(50),
  FOREIGN KEY (meal_id)
    REFERENCES nutrition_meals(id)
    ON DELETE CASCADE
);


============- 4) Create user_nutrition_plans  -============


CREATE TABLE user_nutrition_plans (
  user_id BIGINT UNSIGNED PRIMARY KEY,
  template_id BIGINT UNSIGNED NOT NULL,
  assigned_by BIGINT UNSIGNED,
  assigned_at DATETIME DEFAULT CURRENT_TIMESTAMP,
  FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE,
  FOREIGN KEY (template_id) REFERENCES nutrition_templates(id),
  FOREIGN KEY (assigned_by) REFERENCES users(id)
);


============- 5) Create challenge_submissions  -============
CREATE TABLE challenge_submissions (
  id INT AUTO_INCREMENT PRIMARY KEY,

  user_id INT NOT NULL,
  challenge_id INT NOT NULL,
  day INT NOT NULL,

  video_url VARCHAR(255) NOT NULL,

  status ENUM('PENDING', 'APPROVED', 'REJECTED') DEFAULT 'PENDING',

  submitted_at DATETIME DEFAULT CURRENT_TIMESTAMP,
  reviewed_at DATETIME NULL,

  UNIQUE KEY unique_submission (user_id, challenge_id, day)
);

============- 6) Create challenges  -============
CREATE TABLE challenges (
  id INT AUTO_INCREMENT PRIMARY KEY,
  title VARCHAR(255) NOT NULL,
  description TEXT,
  type ENUM('VIDEO','IMAGE','TEXT') NOT NULL DEFAULT 'VIDEO',
  duration_days INT NOT NULL,
  total_points INT NOT NULL,
  start_date DATE NULL,
  status ENUM('ACTIVE','EXPIRED') NOT NULL DEFAULT 'ACTIVE',
  created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;



