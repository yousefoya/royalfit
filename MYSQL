============- 10) Create training_templates Table-============

CREATE TABLE training_templates (
  id BIGINT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
  name VARCHAR(100) NOT NULL,
  description TEXT,
  created_at DATETIME DEFAULT CURRENT_TIMESTAMP
);



============- 11) Create training_template_exercises Table-============

CREATE TABLE training_template_days (
  id BIGINT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
  template_id BIGINT UNSIGNED NOT NULL,
  day_name ENUM(
    'Sunday','Monday','Tuesday',
    'Wednesday','Thursday','Friday','Saturday'
  ) NOT NULL,
  FOREIGN KEY (template_id)
    REFERENCES training_templates(id)
    ON DELETE CASCADE
);


============- 12) Create training_template_day_exercises Table-============
CREATE TABLE training_template_day_exercises (
  id BIGINT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
  day_id BIGINT UNSIGNED NOT NULL,
  exercise_id BIGINT UNSIGNED NOT NULL,
  sets INT DEFAULT 3,
  reps INT DEFAULT 12,
  notes VARCHAR(255),

  FOREIGN KEY (day_id)
    REFERENCES training_template_days(id)
    ON DELETE CASCADE,

  FOREIGN KEY (exercise_id)
    REFERENCES training_exercises_library(id)
    ON DELETE CASCADE
);


============- 13) Create user_training_plans Table-============

CREATE TABLE user_training_plans (
  user_id BIGINT UNSIGNED PRIMARY KEY,
  template_id BIGINT UNSIGNED NOT NULL,
  assigned_by BIGINT UNSIGNED,
  status ENUM('pending','completed','need_update') DEFAULT 'pending',
  assigned_at DATETIME DEFAULT CURRENT_TIMESTAMP,
  updated_at DATETIME DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,

  FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE,
  FOREIGN KEY (template_id) REFERENCES training_templates(id),
  FOREIGN KEY (assigned_by) REFERENCES users(id)
);



