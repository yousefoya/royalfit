============- 1) users table -============

CREATE DATABASE IF NOT EXISTS royal_fitness
CHARACTER SET utf8mb4
COLLATE utf8mb4_unicode_ci;

USE royal_fitness;


============- 2) users table -============

CREATE TABLE users (
  name VARCHAR(100) NOT NULL,
  phone VARCHAR(15) NOT NULL,
  role ENUM('admin','trainer','member') NOT NULL,
  avatar VARCHAR(255) DEFAULT 'https://i.pinimg.com/736x/2f/15/f2/2f15f2e8c688b3120d3d26467b06330c.jpg',
  trainer_id VARCHAR(36) DEFAULT NULL,
  subscription_end_date DATETIME DEFAULT NULL,
  schedule_status ENUM('pending','in_progress','completed','need_update') DEFAULT NULL,
  schedule_last_updated DATETIME DEFAULT NULL,
  password_hash VARCHAR(255) NOT NULL,
  id INT(10) UNSIGNED NOT NULL AUTO_INCREMENT,
  PRIMARY KEY (id),
  UNIQUE KEY phone (phone)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;


============- 3) messages table -============

CREATE TABLE messages (
  id INT(11) NOT NULL AUTO_INCREMENT,
  sender_id VARCHAR(36) NOT NULL,
  receiver_id VARCHAR(36) NOT NULL,
  text TEXT NOT NULL,
  timestamp DATETIME DEFAULT CURRENT_TIMESTAMP,
  PRIMARY KEY (id)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

============- 4) schedules table -============

CREATE TABLE schedules (
  client_id INT(10) UNSIGNED NOT NULL,
  schedule_text TEXT DEFAULT NULL,
  PRIMARY KEY (client_id),
  CONSTRAINT fk_schedules_client
    FOREIGN KEY (client_id) REFERENCES users(id)
    ON DELETE CASCADE
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

============- 5) Avatar generator -============

ALTER TABLE users
MODIFY avatar VARCHAR(255) NOT NULL
DEFAULT 'https://i.pinimg.com/736x/2f/15/f2/2f15f2e8c688b3120d3d26467b06330c.jpg';



